{
  "name": "global-rare-ebird",
  "version": "0.3.3",
  "title": "Global Rare eBird",
  "description": "A map of all rare birds seen on the globe with eBird data.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zoziologie/global-rare-ebird.git"
  },
  "homepage": "http://zoziologie.raphaelnussbaumer.com/global-rare-ebird/",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "generate:taxonomy": "node scripts/generate-taxonomy.mjs",
    "generate:region-catalog": "node scripts/generate-region-catalog.mjs",
    "generate:aba-taxonomy": "node scripts/generate-aba-taxonomy.mjs",
    "generate:french-taxonomy": "node scripts/generate-french-taxonomy.mjs",
    "generate:german-taxonomy": "node scripts/generate-german-taxonomy.mjs",
    "generate:swiss-taxonomy": "node scripts/generate-swiss-taxonomy.mjs",
    "generate:taxonomies": "npm run generate:taxonomy && npm run generate:region-catalog && npm run generate:aba-taxonomy && npm run generate:french-taxonomy && npm run generate:german-taxonomy && npm run generate:swiss-taxonomy",
    "build": "vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "bootstrap": "^5.3.3",
    "bootstrap-icons": "^1.11.3",
    "mapbox-gl": "^3.7.0",
    "vue": "^3.5.13",
    "vue-multiselect": "^3.5.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.1",
    "sass": "^1.82.0",
    "vite": "^6.0.2"
  }
